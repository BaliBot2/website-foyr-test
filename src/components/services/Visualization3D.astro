---
// 3D Visualization service section — pull quote on photo-realistic renders
---

<section id="visualization-3d" class="py-24 bg-background-light dark:bg-background-dark">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Content -->
      <div class="space-y-8">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="h-px w-12 bg-primary" />
            <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary font-display">Category C — Premium</span>
          </div>
          <h2 class="font-display font-black uppercase text-stone-900 dark:text-stone-100 leading-tight" style="font-size: clamp(2rem, 4vw, 3.5rem);">
            3D Visualization<br />&amp; Rendering
          </h2>
        </div>

        <!-- Pull quote -->
        <blockquote
          class="border-l-4 pl-6 py-2"
          style="border-color: var(--color-primary);"
        >
          <p
            class="font-display font-black text-xl md:text-2xl leading-snug"
            style="color: var(--color-primary);"
          >
            "Photo-realistic 3D that helps clients see their space visually complete — even before spending any money on construction."
          </p>
        </blockquote>

        <p class="font-sans text-stone-600 dark:text-stone-400 leading-relaxed">
          Our premium 3D visualization service removes all guesswork. You see your home, office, or commercial space in stunning photorealistic detail — materials, lighting, furniture layout — before a single fixture is ordered.
        </p>

        <!-- What's included -->
        <div
          class="p-6 rounded-lg space-y-3"
          style="background-color: color-mix(in srgb, var(--color-primary) 5%, transparent); border: 1px solid color-mix(in srgb, var(--color-primary) 15%, transparent);"
        >
          <p class="font-display font-black text-xs uppercase tracking-widest text-primary">Services Included</p>
          <ul class="space-y-2">
            {[
              'Photorealistic 3D interior views — all rooms',
              '3D exterior elevation renders',
              'Multiple lighting conditions (day / evening)',
              'Unlimited revisions until approved',
            ].map((item) => (
              <li class="flex items-center gap-3 font-sans text-sm text-stone-700 dark:text-stone-300">
                <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />
                {item}
              </li>
            ))}
          </ul>
        </div>

        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-light text-primary-contrast px-8 py-4 rounded font-bold uppercase tracking-widest text-sm transition-all duration-200 hover:scale-105"
        >
          Get a 3D Render Quote
        </a>
      </div>

      <!-- Right: Render placeholder -->
      <div class="space-y-4">
        <div
          class="rounded-lg overflow-hidden aspect-video relative"
          style="background: linear-gradient(135deg, var(--color-primary) 0%, #3D1805 100%);"
        >
          <div
            class="absolute inset-0 flex items-center justify-center font-display font-black uppercase opacity-10"
            style="font-size: 5rem; color: var(--color-primary-contrast);"
          >
            3D
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-4 text-center" style="background: linear-gradient(to top, rgba(26,16,8,0.7) 0%, transparent 100%);">
            <p class="font-sans text-[10px] uppercase tracking-widest" style="color: color-mix(in srgb, var(--color-primary-contrast) 50%, transparent);">
              3D Render — Photorealistic Interior | PDF P.42
            </p>
          </div>
        </div>
        <div
          class="rounded-lg overflow-hidden aspect-video relative"
          style="background: linear-gradient(135deg, #4A3728 0%, #2A1F16 100%);"
        >
          <div
            class="absolute inset-0 flex items-center justify-center font-display font-black uppercase opacity-10"
            style="font-size: 5rem; color: var(--color-primary-contrast);"
          >
            EXT
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-4 text-center" style="background: linear-gradient(to top, rgba(26,16,8,0.7) 0%, transparent 100%);">
            <p class="font-sans text-[10px] uppercase tracking-widest" style="color: color-mix(in srgb, var(--color-primary-contrast) 50%, transparent);">
              3D Exterior Elevation Render | PDF P.42
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
