---
// FeaturedProjects.astro — 3 featured project cards
import { featuredProjects } from '../../data/projects';

// Placeholder color palettes for 3 featured projects
const placeholderGradients = [
  'linear-gradient(135deg, #8B3A0F 0%, #5C2408 100%)',
  'linear-gradient(135deg, #6B2D0A 0%, #3D1805 100%)',
  'linear-gradient(135deg, #A04515 0%, #6B2D0A 100%)',
];
---

<section id="featured-projects" class="py-24 bg-background-light dark:bg-background-dark">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-6">
      <div>
        <div class="flex items-center gap-4 mb-4">
          <div class="h-px w-12 bg-primary" />
          <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary font-display">Selected Works</span>
        </div>
        <h2 class="font-display font-black uppercase text-stone-900 dark:text-stone-100 leading-tight" style="font-size: clamp(2rem, 5vw, 3.5rem);">
          Featured<br />Projects
        </h2>
      </div>
      <a
        href="/projects"
        class="self-start md:self-end inline-flex items-center gap-2 border-2 border-primary text-primary hover:bg-primary hover:text-primary-contrast px-6 py-3 rounded font-bold uppercase tracking-widest text-sm transition-all duration-200"
      >
        View All Projects
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {featuredProjects.slice(0, 3).map((project, i) => (
        <article
          class="group cursor-pointer"
          onclick={`window.location.href='/projects#${project.slug}'`}
        >
          <!-- Image placeholder -->
          <div
            class="relative overflow-hidden rounded-lg mb-4 aspect-[4/3]"
            style={`background: ${placeholderGradients[i % placeholderGradients.length]};`}
          >
            <!-- DS watermark -->
            <div
              class="absolute inset-0 flex items-center justify-center opacity-10 font-display font-black uppercase"
              style="font-size: 5rem; color: var(--color-primary-contrast); letter-spacing: -0.05em;"
            >
              DS
            </div>
            <!-- Type badge -->
            <div class="absolute top-4 left-4">
              <span
                class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full font-display"
                style="background-color: color-mix(in srgb, var(--color-primary-contrast) 90%, transparent); color: var(--color-primary);"
              >
                {project.type}
              </span>
            </div>
            <!-- Hover overlay -->
            <div
              class="absolute inset-0 flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              style="background: linear-gradient(to top, rgba(26,16,8,0.8) 0%, transparent 60%);"
            >
              <span class="font-sans text-xs font-semibold uppercase tracking-widest" style="color: var(--color-primary-contrast);">
                View Project →
              </span>
            </div>
            <!-- Scale on hover -->
            <div
              class="absolute inset-0 transition-transform duration-700 group-hover:scale-105"
              style={`background: ${placeholderGradients[i % placeholderGradients.length]};`}
            />
          </div>

          <!-- Info -->
          <div class="flex justify-between items-start gap-4">
            <div>
              <h3 class="font-display font-black text-lg uppercase text-stone-900 dark:text-stone-100 group-hover:text-primary transition-colors duration-200">
                {project.name}
              </h3>
              <p class="font-sans text-sm text-stone-500 dark:text-stone-400 mt-1 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {project.location}
              </p>
            </div>
            {project.sqft && (
              <span class="font-sans text-xs text-stone-400 whitespace-nowrap">
                {project.sqft.toLocaleString()} sq.ft.
              </span>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
